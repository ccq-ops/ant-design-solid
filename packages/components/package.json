{
  "name": "@ant-design-solid/core",
  "version": "0.0.0",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.json --emitDeclarationOnly",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint src"
  },
  "dependencies": {
    "@ant-design-solid/cssinjs": "workspace:*",
    "@ant-design-solid/icons": "workspace:*",
    "@ant-design-solid/theme": "workspace:*",
    "@tanstack/solid-virtual": "^3.13.28",
    "dayjs": "^1.11.13",
    "solid-motionone": "^1.0.4"
  },
  "peerDependencies": {
    "solid-js": ">=1.9.0"
  }
}
