{
  "name": "ant-design-solid",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @ant-design-solid/docs dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "typecheck": "pnpm -r typecheck",
    "lint": "oxlint .",
    "format": "oxfmt --write .",
    "lint:fix": "oxlint . --fix",
    "format:check": "oxfmt --check ."
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@solidjs/testing-library": "latest",
    "@testing-library/jest-dom": "latest",
    "@types/node": "latest",
    "jsdom": "latest",
    "oxfmt": "^0.52.0",
    "oxlint": "^1.67.0",
    "solid-js": "latest",
    "typescript": "latest",
    "vite": "^8.0.0",
    "vite-plugin-solid": "latest",
    "vitest": "latest"
  },
  "engines": {
    "node": ">=22",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.0.0"
}
